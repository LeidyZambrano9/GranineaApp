<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="16dp">




    <!-- Título -->
    <TextView
        android:id="@+id/tvDetallePedidoTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/pedido_32"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Cliente -->
    <TextView
        android:id="@+id/tvDetallePedidoCliente"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/cliente_adriana_guti_rrez"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvDetallePedidoTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Productos (Scrollable) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvDetallePedidoCliente"
        app:layout_constraintBottom_toTopOf="@id/tvDetallePedidoTotal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvDetallePedidoProductos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/productos_n_granizado_fresa_n_cantidad_2_precio_4_000_n_granizado_mango_n_cantidad_2_precio_6_000"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:lineSpacingExtra="4dp"
            android:padding="8dp"
            android:background="@color/white" />
    </androidx.core.widget.NestedScrollView>

    <!-- Total -->
    <TextView
        android:id="@+id/tvDetallePedidoTotal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/total_18_000"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="end"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnMarcarEntregadoDetalle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón Marcar Entregado (aparece solo si es pendiente) -->
    <Button
        android:id="@+id/btnMarcarEntregadoDetalle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/marcar_como_entregado"
        android:backgroundTint="@color/green"
        android:textColor="@color/white"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnVolverDetalle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón Volver -->
    <Button
        android:id="@+id/btnVolverDetalle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/volver"
        android:backgroundTint="@color/blue"
        android:textColor="@color/text_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>