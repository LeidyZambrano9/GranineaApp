<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="16dp">

    <!-- Título -->
    <TextView
        android:id="@+id/tvTituloEditar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/editar_producto"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Nombre -->
    <TextView
        android:id="@+id/labelNombreEditar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nombre *"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/tvTituloEditar"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etEditarNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:backgroundTint="@color/primary"
        app:layout_constraintTop_toBottomOf="@id/labelNombreEditar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Descripción -->
    <TextView
        android:id="@+id/labelDescripcionEditar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Descripción"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/etEditarNombre"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etEditarDescripcion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="textMultiLine"
        android:minLines="2"
        android:backgroundTint="@color/primary"
        app:layout_constraintTop_toBottomOf="@id/labelDescripcionEditar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Precio y Tamaño -->
    <LinearLayout
        android:id="@+id/rowPrecioTamanioEditar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/etEditarDescripcion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Precio *"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etEditarPrecio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tamaño *"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etEditarTamanio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:backgroundTint="@color/primary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Sabores -->
    <TextView
        android:id="@+id/labelSaboresEditar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Sabores disponibles (separados por coma)"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/rowPrecioTamanioEditar"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etEditarSabores"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:backgroundTint="@color/primary"
        app:layout_constraintTop_toBottomOf="@id/labelSaboresEditar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón Guardar -->
    <Button
        android:id="@+id/btnGuardarEdicion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Guardar cambios"
        android:backgroundTint="@color/primary"
        android:textColor="@color/text_white"
        android:layout_marginTop="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>