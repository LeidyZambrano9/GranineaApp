<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- LOGO -->
        <ImageView
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/logo_graninea"
            android:scaleType="fitCenter"
            android:layout_marginBottom="16dp"/>

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/restablecer_contra1"
            android:textColor="#39FF88"
            android:textSize="24sp"
            android:textStyle="italic"
            android:layout_marginBottom="32dp"
            android:gravity="center"/>

        <!-- CORREO -->
        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="@string/placeholder_correo_restablecer"
            android:textColorHint="#AAAAAA"
            android:textColor="#FFFFFF"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_edittext"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="16dp"/>

        <!-- BOTON ENVIAR -->
        <Button
            android:id="@+id/btn_enviar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/boton_enviar_restablecer"
            android:textStyle="bold"
            android:textSize="15sp"
            android:letterSpacing="0.1"
            android:textColor="#000000"
            android:backgroundTint="#39FF14"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

</ScrollView>