<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_fondo">

    <!-- LOGO (AJUSTADO) -->
    <ImageView
        android:id="@+id/logo_catalogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:src="@drawable/logo_graninea"
        android:scaleType="fitCenter"
        android:maxHeight="100dp"
        android:adjustViewBounds="true"/>

    <!-- BUSCADOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp">

        <EditText
            android:id="@+id/buscador"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:hint="@string/hint_busqueda_catalogo"
            android:background="@drawable/bg_search"
            android:padding="10dp"/>

        <ImageView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_cart"
            android:background="@drawable/bg_search"
            android:padding="10dp"/>
    </LinearLayout>

    <!-- FILTROS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <TextView
            android:text="@string/sin_licor_filter"
            style="@style/FiltroStyle"/>

        <TextView
            android:text="@string/con_licor_filter"
            style="@style/FiltroStyle"/>

        <TextView
            android:text="@string/xl_filter"
            style="@style/FiltroStyle"/>
    </LinearLayout>

    <!-- LISTA PRODUCTOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_productos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"/>

</LinearLayout>