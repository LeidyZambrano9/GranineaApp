<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:padding="16dp">

    <!-- ✅ Botones de acción del admin -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnCrearProductoAdmin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="➕ Crear Producto"
            android:backgroundTint="@color/green"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnEditarProductoAdmin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="✏️ Editar Producto"
            android:backgroundTint="@color/blue"
            android:textColor="@color/white" />
        <!-- ✅ Oculto: se usa el click en el producto para editar -->
    </LinearLayout>

    <!-- ✅ Lista de productos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_productos_admin"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>