<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- FECHA -->
            <TextView
                android:id="@+id/tv_fecha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fecha_detalle_pedido"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <!-- TARJETA PEDIDO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#E8E8E8"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- TITULO PEDIDO -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pedido_tittle"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>

                <!-- CLIENTE -->
                <TextView
                    android:id="@+id/tv_cliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/nombre_cliente_detalle_pedido"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- PRODUCTOS LABEL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/productos_pedido"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <!-- PRODUCTO 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">
                    <TextView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="#39FF14"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/tv_producto1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/granizado_fresa"
                        android:textColor="#000000"
                        android:textSize="14sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_cantidad1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cantidad_2"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tv_precio1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/precio_producto_1"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="10dp"/>

                <!-- PRODUCTO 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">
                    <TextView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="#39FF14"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/tv_producto2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/producto2_pedido"
                        android:textColor="#000000"
                        android:textSize="14sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_cantidad2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cantidad_producto_2"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tv_precio2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/precio_producto_dos"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="12dp"/>

                <!-- DIVISOR -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#AAAAAA"
                    android:layout_marginBottom="10dp"/>

                <!-- TOTAL -->
                <TextView
                    android:id="@+id/tv_total"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/total_pedido"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- BOTON VOLVER fijo abajo -->
    <Button
        android:id="@+id/btn_volver"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:text="@string/volver_boton"
        android:textStyle="bold|italic"
        android:textSize="18sp"
        android:textColor="#000000"
        android:backgroundTint="#39FF14"
        android:stateListAnimator="@null"/>

</FrameLayout>