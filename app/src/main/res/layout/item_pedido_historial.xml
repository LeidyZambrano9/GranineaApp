<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Título y Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPedidoTitulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pedido #32"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvPedidoEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENTREGADO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@color/estado_entregado"
                android:textColor="@color/text_white" />
        </LinearLayout>

        <!-- Detalle resumido -->
        <TextView
            android:id="@+id/tvPedidoDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detalle del pedido"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

        <!-- Solo botón Ver Detalle -->
        <Button
            android:id="@+id/btnVerDetallePedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ver Detalle"
            android:textSize="12sp"
            android:backgroundTint="@color/color_pedidos"
            android:textColor="@color/text_white" />

    </LinearLayout>
</androidx.cardview.widget.CardView>