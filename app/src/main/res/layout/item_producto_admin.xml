<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="center_horizontal">

        <!-- Imagen (icono nativo) -->
        <ImageView
            android:id="@+id/ivProductoImagen"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_menu_manage"
            android:contentDescription="Imagen del producto"
            app:tint="@color/color_productos" />

        <!-- Nombre -->
        <TextView
            android:id="@+id/tvProductoNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Granizado fresa"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="8dp" />

        <!-- Tamaño -->
        <TextView
            android:id="@+id/tvProductoTamanio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="500ml"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="2dp" />

        <!-- Precio -->
        <TextView
            android:id="@+id/tvProductoPrecio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="$2.000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/color_productos"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <!-- Botones Admin -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnEditarProducto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Editar"
                android:textSize="11sp"
                android:backgroundTint="@color/color_pedidos"
                android:textColor="@color/text_white" />

            <Button
                android:id="@+id/btnEliminarProducto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Eliminar"
                android:textSize="11sp"
                android:backgroundTint="@color/error"
                android:textColor="@color/text_white" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>