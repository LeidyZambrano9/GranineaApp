<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="center_horizontal">

        <!-- Imagen (icono nativo) -->
        <ImageView
            android:id="@+id/ivProductoImagen"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_menu_add"
            android:contentDescription="Imagen del producto"
            app:tint="@color/color_productos" />

        <!-- Nombre -->
        <TextView
            android:id="@+id/tvProductoNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Granizado fresa"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="8dp" />

        <!-- Tamaño -->
        <TextView
            android:id="@+id/tvProductoTamanio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="500ml"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="2dp" />

        <!-- Precio -->
        <TextView
            android:id="@+id/tvProductoPrecio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="$2.000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/color_productos"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <!-- Botón Agregar al carrito -->
        <Button
            android:id="@+id/btnAgregarCarrito"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Agregar"
            android:textSize="12sp"
            android:backgroundTint="@color/primary"
            android:textColor="@color/text_white"
            android:drawableStart="@android:drawable/ic_menu_add"
            android:drawablePadding="4dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>